# Alternative minimal nginx template
# Generated by Nginx Configuration Manager
# Template: minimal.j2

worker_processes {{ Global.WorkerProcesses }};
error_log /var/log/nginx/error.log warn;

events {
    worker_connections {{ Global.WorkerConnections }};
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    
    sendfile on;
    keepalive_timeout {{ Global.KeepAliveTimeout }};
    
    {% if not Global.ServerTokens %}server_tokens off;{% endif %}
    
    {% for backend in Backends %}
    upstream {{ backend.ID }} {
        {% for server in backend.Servers %}
        server {{ server.Host }}:{{ server.Port }};
        {% endfor %}
    }
    {% endfor %}

    {% for server in Servers %}
    server {
        {% for listen_port in server.Listen %}listen {{ listen_port }};{% endfor %}
        {% for server_name in server.ServerName %}server_name {{ server_name }};{% endfor %}

        {% for route in server.Routes %}
        location {{ route.Path }} {
            proxy_pass http://{{ route.BackendID }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }
        {% endfor %}
    }
    {% endfor %}
}
