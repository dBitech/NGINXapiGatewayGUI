# Development nginx template with debugging
# Generated by Nginx Configuration Manager
# Template: development.j2

worker_processes 1;
error_log /var/log/nginx/error.log debug;

events {
    worker_connections 1024;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    
    # Development settings
    sendfile off;
    keepalive_timeout 30s;
    server_tokens on;
    
    # Debug logging
    access_log /var/log/nginx/access.log combined;
    
    {% for backend in Backends %}
    upstream {{ backend.ID }} {
        {% for server in backend.Servers %}
        server {{ server.Host }}:{{ server.Port }};
        {% endfor %}
    }
    {% endfor %}

    {% for server in Servers %}
    server {
        {% for listen_port in server.Listen %}listen {{ listen_port }};{% endfor %}
        {% for server_name in server.ServerName %}server_name {{ server_name }};{% endfor %}

        # Development CORS headers
        add_header 'Access-Control-Allow-Origin' '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET,POST,PUT,DELETE,OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range' always;

        {% for route in server.Routes %}
        location {{ route.Path }} {
            # Debug headers
            add_header X-Debug-Backend "{{ route.BackendID }}" always;
            add_header X-Debug-Route "{{ route.Name }}" always;
            
            proxy_pass http://{{ route.BackendID }};
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            
            # Development timeouts
            proxy_connect_timeout 5s;
            proxy_send_timeout 5s;
            proxy_read_timeout 5s;
        }
        {% endfor %}
        
        # Health check endpoint
        location /health {
            access_log off;
            return 200 "healthy\n";
            add_header Content-Type text/plain;
        }
    }
    {% endfor %}
}
