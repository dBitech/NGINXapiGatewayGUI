# Generated by Nginx Configuration Manager
# DO NOT EDIT MANUALLY - Changes will be overwritten


worker_processes {{ Global.WorkerProcesses }};
error_log /var/log/nginx/error.log;
pid /run/nginx.pid;

events {
    worker_connections {{ Global.WorkerConnections }};
}

http {
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for"';

    access_log /var/log/nginx/access.log main;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout {{ Global.KeepAliveTimeout }};
    types_hash_max_size 2048;
    {% if not Global.ServerTokens %}server_tokens off;{% endif %}
    client_max_body_size {{ Global.ClientMaxBodySize }};

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    {% if Global.Gzip %}
    # Gzip Settings
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        {% for gzip_type in Global.GzipTypes %}{{ gzip_type }}
        {% endfor %};
    {% endif %}

    # Rate limiting zones
    limit_req_zone $binary_remote_addr zone=api:10m rate=10r/s;
    limit_req_zone $binary_remote_addr zone=login:10m rate=1r/s;

    # Proxy cache configuration
    proxy_cache_path /var/cache/nginx levels=1:2 keys_zone=cache_zone:10m max_size=1g 
                     inactive=60m use_temp_path=off;
    proxy_temp_path /var/cache/nginx/temp;

    # Upstream backends
    {% for backend in Backends %}
    upstream {{ backend.ID }} {
        {% if backend.HealthCheck and backend.HealthCheck.Enabled %}
        # Active health checks require nginx-plus or custom module
        zone {{ backend.ID }} 64k;
        {% endif %}
        {% if backend.LoadBalance == "least_conn" %}least_conn;{% endif %}
        {% if backend.LoadBalance == "ip_hash" %}ip_hash;{% endif %}
        {% for server in backend.Servers %}
        server {{ server.Host }}:{{ server.Port }}{% if server.Weight %} weight={{ server.Weight }}{% endif %}{% if server.Backup %} backup{% endif %}{% if server.Down %} down{% endif %}{% if backend.MaxFails %} max_fails={{ backend.MaxFails }}{% endif %}{% if backend.FailTimeout %} fail_timeout={{ backend.FailTimeout }}{% endif %};
        {% endfor %}
        {% if backend.HealthCheck and backend.HealthCheck.Enabled %}
        # Third-party module health check (nginx-upstream-check-module)
        check interval=5000 rise={{ backend.HealthCheck.Rises | default:2 }} fall={{ backend.HealthCheck.Falls | default:3 }} timeout=4000{% if backend.HealthCheck.Path %} type=http{% endif %};
        {% if backend.HealthCheck.Path %}
        check_http_send "{{ backend.HealthCheck.Method | default:"GET" }} {{ backend.HealthCheck.Path }} HTTP/1.0\r\n{% if backend.HealthCheck.Headers %}{% for header_name, header_value in backend.HealthCheck.Headers %}{{ header_name }}: {{ header_value }}\r\n{% endfor %}{% endif %}\r\n{% if backend.HealthCheck.Body %}{{ backend.HealthCheck.Body }}{% endif %}";
        check_http_expect_alive{% if backend.HealthCheck.Match and backend.HealthCheck.Match.StatusCodes %} {% for code in backend.HealthCheck.Match.StatusCodes %}http_{{ code }}{% if not forloop.last %} {% endif %}{% endfor %}{% else %} http_2xx http_3xx{% endif %};
        {% endif %}
        {% endif %}
    }
    {% endfor %}

    # Server configurations
    {% for server in Servers %}
    server {
        {% for listen_port in server.Listen %}listen {{ listen_port }};{% endfor %}
        {% for server_name in server.ServerName %}server_name {{ server_name }};{% endfor %}

        {% if server.SSL and server.SSL.Enabled %}
        # SSL Configuration
        ssl_certificate {{ server.SSL.Certificate }};
        ssl_certificate_key {{ server.SSL.PrivateKey }};
        ssl_protocols {% for protocol in server.SSL.Protocols %}{{ protocol }} {% endfor %};
        ssl_ciphers {{ server.SSL.Ciphers }};
        ssl_prefer_server_ciphers on;
        {% if server.SSL.Redirect %}
        # Redirect HTTP to HTTPS
        if ($scheme != "https") {
            return 301 https://$host$request_uri;
        }
        {% endif %}
        {% endif %}

        {% if server.AccessLog %}access_log {{ server.AccessLog }};{% endif %}
        {% if server.ErrorLog %}error_log {{ server.ErrorLog }};{% endif %}
        {% if server.ClientMaxBodySize %}client_max_body_size {{ server.ClientMaxBodySize }};{% endif %}

        # Custom headers
        {% for header_name, header_value in server.Headers.items() %}
        add_header {{ header_name }} "{{ header_value }}" always;
        {% endfor %}

        # Routes
        {% for route in server.Routes %}
        {% include 'route.j2' %}
        {% endfor %}

        # Default error pages
        error_page 404 /404.html;
        error_page 500 502 503 504 /50x.html;
        location = /50x.html {
            root /usr/share/nginx/html;
        }
    }
    {% endfor %}
}
